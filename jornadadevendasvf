<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Identidade & Rotina Operacional — Yandeh</title>

<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;900&family=Barlow:wght@400;500;600&display=swap" rel="stylesheet">

<style>
:root {
  --orange: #E8471A;
  --dark: #000202;
  --dark-2: #1a1919;
  --white: #FFFFFF;
  --gray: #9896B0;
}

body {
  font-family: 'Barlow', sans-serif;
  background: var(--dark);
  color: var(--white);
}

/* BOTÃO QUIZ */
.btn-quiz {
  padding: 20px 30px;
  background: var(--orange);
  border: none;
  color: white;
  cursor: pointer;
  border-radius: 10px;
  font-weight: bold;
}

/* MODAL */
.modal {
  display: none;
  position: fixed;
  z-index: 999;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.7);
}

.modal-content {
  background: #1a1d2e;
  width: 90%;
  max-width: 500px;
  padding: 2rem;
  border-radius: 10px;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.quiz-options button {
  padding: 14px;
  background: var(--orange);
  border: none;
  color: white;
  border-radius: 6px;
  cursor: pointer;
}

.quiz-result {
  margin-top: 20px;
  font-weight: bold;
  font-size: 1.5rem;
}
</style>
</head>

<body>

<section id="quiz" style="padding:60px; text-align:center;">

<h1>Você é protagonista ou operacional?</h1>

<button class="btn-quiz" onclick="abrirQuiz()">
  Fazer diagnóstico
</button>

<div id="quizModal" class="modal">
  <div class="modal-content">

    <span onclick="fecharQuiz()" style="cursor:pointer; float:right;">X</span>

    <h2>Você é protagonista?</h2>

    <p id="question"></p>

    <div class="quiz-options">
      <button onclick="answer(2)">Sempre</button>
      <button onclick="answer(1)">Às vezes</button>
      <button onclick="answer(0)">Nunca</button>
    </div>

    <p id="result" class="quiz-result"></p>

  </div>
</div>

</section>

<script>
const questions = [
  "Você analisa o PDV antes de falar com o cliente?",
  "Você sugere mix baseado em dados?",
  "Você faz pós-venda ativo?",
  "Você antecipa problemas do cliente?"
];

let currentQ = 0;
let score = 0;

function abrirQuiz() {
  document.getElementById("quizModal").style.display = "block";
  resetQuiz();
}

function fecharQuiz() {
  document.getElementById("quizModal").style.display = "none";
}

function resetQuiz() {
  currentQ = 0;
  score = 0;
  document.getElementById("result").textContent = "";
  showQuestion();
}

function showQuestion() {
  document.getElementById("question").textContent = questions[currentQ];
}

function answer(value) {
  score += value;
  currentQ++;

  if (currentQ < questions.length) {
    showQuestion();
  } else {
    showResult();
  }
}

function showResult() {
  let textoFinal = "";

  if (score >= 6) {
    textoFinal = "🔥 Protagonista forte";
  } else if (score >= 3) {
    textoFinal = "⚡ Em evolução";
  } else {
    textoFinal = "⚠️ Perfil operacional";
  }

  document.getElementById("result").innerText = textoFinal;
}
</script>

</body>
</html>
